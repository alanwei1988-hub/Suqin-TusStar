{
  "agent": {
    "model": "gemini-3.1-flash-lite-preview",
    "provider": "openai",
    "openai": {
      "baseURL": "https://api.zetatechs.com/v1"
    },
    "toolChoice": "auto",
    "maxSteps": 12,
    "context": {
      "loopMessageWindow": 30,
      "recentMessagesCount": 12,
      "summaryLineCount": 10,
      "summaryMaxChars": 240
    },
    "mcpServers": [
      {
        "name": "contract-manager",
        "transport": "stdio",
        "command": "node",
        "args": ["./contract-mcp/server.js"],
        "cwd": ".",
        "failOpen": false,
        "initTimeoutMs": 8000
      }
    ],
    "attachmentExtraction": {
      "markitdown": {
        "enabled": true,
        "command": "{runner}",
        "args": [
          "./markitdown/runner.py",
          "--use-plugins",
          "--llm-client",
          "{llmClient}",
          "--llm-model",
          "{llmModel}",
          "--llm-base-url",
          "{llmBaseURL}",
          "{input}"
        ],
        "timeoutMs": 60000,
        "maxOutputChars": 24000,
        "supportedExtensions": [".pdf", ".docx", ".pptx", ".xls", ".xlsx"],
        "llm": {
          "client": "openai",
          "model": "gemini-3.1-flash-lite-preview",
          "baseURL": "https://api.zetatechs.com/v1",
          "apiKeyEnv": "MARKITDOWN_OCR_OPENAI_API_KEY"
        }
      }
    },
    "skillsDir": "./skills",
    "rolePromptDir": "./roles/contract-manager",
    "sessionDb": "./data/sessions.db"
  },
  "contractMcp": {
    "libraryRoot": "\\\\192.168.20.100\\启迪之星\\技术商业化事业部\\板块-产业化\\合同管理",
    "contractIdPrefix": "CT",
    "allowedExtensions": [".pdf", ".doc", ".docx", ".jpg", ".jpeg", ".png"],
    "maxFileSizeMb": 50,
    "defaultSearchLimit": 20
  },
  "channel": {
    "type": "wxwork",
    "wxwork": {
      "debug": true,
      "streamingResponse": true
    }
  },
  "storage": {
    "tempDir": "./storage/temp"
  }
}
