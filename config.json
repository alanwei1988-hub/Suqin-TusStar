{
  "agent": {
    "model": "gpt-5.4",
    "provider": "openai",
    "thinking": false,
    "openai": {
      "baseURL": "https://api.zetatechs.com/v1"
    },
    "imageModel": {
      "enabled": true,
      "model": "gpt-5.4",
      "baseURL": "https://api.zetatechs.com/v1",
      "apiKeyEnv": "OPENAI_API_KEY",
      "timeoutMs": 60000,
      "prompt": "Inspect this image. Summarize the visible content, the main subject, the scene, and any clearly readable text. Keep the response concise and factual."
    },
    "toolChoice": "auto",
    "maxSteps": 12,
    "maxContinuationAttempts": 1,
    "workspacePython": {
      "enabled": true,
      "command": "{runtime}",
      "timeoutMs": 120000,
      "maxTimeoutMs": 600000,
      "requirementsPath": "./workspace-runtime/requirements.txt",
      "allowUserPackageInstall": true
    },
    "imageGeneration": {
      "enabled": true,
      "scriptPath": "./workspace-runtime/generate_image.py",
      "timeoutMs": 200000,
      "maxTimeoutMs": 200000,
      "outputDir": "generated-images",
      "defaultResolution": "1K",
      "currentProfile": "zetatechs",
      "profiles": {
        "zetatechs": {
          "apiKeyEnv": "OPENAI_API_KEY",
          "baseUrl": "https://api.zetatechs.com",
          "model": "gemini-3-pro-image-preview"
        },
        "apiyi": {
          "apiKeyEnv": "APIYI_API_KEY",
          "baseUrl": "https://api.apiyi.com",
          "model": "gemini-3.1-flash-image-preview",
          "_model": "nano banana pro"
        }
      }
    },
    "webSearch": {
      "enabled": true,
      "provider": "duckduckgo",
      "maxResults": 5,
      "timeoutMs": 12000
    },
    "toolTimeouts": {
      "bashTimeoutMs": 30000,
      "maxBashTimeoutMs": 300000,
      "mcpToolTimeoutMs": 30000
    },
    "context": {
      "loopMessageWindow": 30,
      "recentMessagesCount": 12,
      "summaryLineCount": 10,
      "summaryMaxChars": 240
    },
    "memory": {
      "reflectionIntervalTurns": 15,
      "dialogueLimit": 20,
      "asyncReflectionEnabled": true
    },
    "mcpServers": [
      {
        "name": "contract-manager",
        "transport": "stdio",
        "command": "node",
        "args": ["./contract-mcp/server.js"],
        "cwd": ".",
        "failOpen": false,
        "initTimeoutMs": 8000,
        "toolTimeoutMs": 30000
      }
    ],
    "attachmentExtraction": {
      "markitdown": {
        "enabled": true,
        "command": "{runner}",
        "args": [
          "./markitdown/runner.py",
          "--use-plugins",
          "--llm-client",
          "{llmClient}",
          "--llm-model",
          "{llmModel}",
          "--llm-base-url",
          "{llmBaseURL}",
          "--llm-prompt",
          "{llmPrompt}",
          "--page-start",
          "{pageStart}",
          "--page-count",
          "{pageCount}",
          "--ocr-concurrency",
          "{ocrConcurrency}",
          "--ocr-page-group-size",
          "{ocrPageGroupSize}",
          "{input}"
        ],
        "timeoutMs": 60000,
        "maxOutputChars": 24000,
        "previewPageCount": 1,
        "readPageCount": 2,
        "ocrConcurrency": 6,
        "ocrPageGroupSize": 1,
        "supportedExtensions": [".pdf", ".docx", ".pptx", ".xls", ".xlsx"],
        "cache": {
          "enabled": true,
          "dbPath": "./data/attachment-extraction-cache.db"
        },
        "activeLlmProfile": "qwen-vl",
        "fallbackLlmProfile": "legacy-openai-compatible",
        "llmProfiles": {
          "legacy-openai-compatible": {
            "client": "openai",
            "model": "gemini-3.1-flash-lite-preview",
            "baseURL": "https://api.zetatechs.com/v1",
            "apiKeyEnv": "MARKITDOWN_OCR_OPENAI_API_KEY",
            "prompt": "Extract all text from this image. Return ONLY the extracted text, maintaining the original layout and order. Do not add any commentary or description."
          },
          "qwen-vl": {
            "client": "qwen",
            "model": "qwen3-vl-flash",
            "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1",
            "apiKeyEnv": "DASHSCOPE_API_KEY",
            "prompt": "qwenvl markdown",
            "thinking": {
              "enabled": false
            }
          }
        }
      }
    },
    "skillsDir": "./skills",
    "rolePromptDir": "./roles/suqin",
    "sessionDb": "./data/sessions.db"
  },
  "contractMcp": {
    "libraryRoot": "\\\\192.168.20.100\\启迪之星\\已签署协议电子档",
    "_libraryRoot": "storage/已签署协议电子档",
    "dbPath": "协议台账_agent.db",
    "archiveIdPrefix": "Agent_",
    "ourCompanyAliases": ["上海启迪创业孵化器有限公司", "上海启迪创业孵化器", "上海启迪"],
    "allowedExtensions": [".pdf", ".doc", ".docx", ".jpg", ".jpeg", ".png", ".xls", ".xlsx"],
    "maxFileSizeMb": 50,
    "defaultSearchLimit": 20
  },
  "channel": {
    "type": "wxwork",
    "wxwork": {
      "debug": true,
      "streamingResponse": true
    }
  },
  "storage": {
    "tempDir": "./storage/temp",
    "userRootDir": "./storage/users"
  }
}
