{
  "agent": {
    "model": "qwen3.5-plus",
    "provider": "openai",
    "openai": {
      "baseURL": "https://api.zetatechs.com/v1"
    },
    "toolChoice": "auto",
    "maxSteps": 12,
    "context": {
      "loopMessageWindow": 30,
      "recentMessagesCount": 12,
      "summaryLineCount": 10,
      "summaryMaxChars": 240
    },
    "mcpServers": [
      {
        "name": "contract-manager",
        "transport": "stdio",
        "command": "node",
        "args": ["./contract-mcp/server.js"],
        "cwd": ".",
        "failOpen": false,
        "initTimeoutMs": 8000
      }
    ],
    "attachmentExtraction": {
      "markitdown": {
        "enabled": true,
        "command": "{runner}",
        "args": [
          "./markitdown/runner.py",
          "--use-plugins",
          "--llm-client",
          "{llmClient}",
          "--llm-model",
          "{llmModel}",
          "--llm-base-url",
          "{llmBaseURL}",
          "--llm-prompt",
          "{llmPrompt}",
          "--page-start",
          "{pageStart}",
          "--page-count",
          "{pageCount}",
          "--ocr-concurrency",
          "{ocrConcurrency}",
          "--ocr-page-group-size",
          "{ocrPageGroupSize}",
          "{input}"
        ],
        "timeoutMs": 60000,
        "maxOutputChars": 24000,
        "previewPageCount": 1,
        "readPageCount": 2,
        "ocrConcurrency": 6,
        "ocrPageGroupSize": 1,
        "supportedExtensions": [".pdf", ".docx", ".pptx", ".xls", ".xlsx"],
        "cache": {
          "enabled": true,
          "dbPath": "./data/attachment-extraction-cache.db"
        },
        "activeLlmProfile": "legacy-openai-compatible",
        "fallbackLlmProfile": "legacy-openai-compatible",
        "llmProfiles": {
          "legacy-openai-compatible": {
            "client": "openai",
            "model": "gemini-3.1-flash-lite-preview",
            "baseURL": "https://api.zetatechs.com/v1",
            "apiKeyEnv": "MARKITDOWN_OCR_OPENAI_API_KEY",
            "prompt": "Extract all text from this image. Return ONLY the extracted text, maintaining the original layout and order. Do not add any commentary or description."
          },
          "qwen-vl": {
            "client": "qwen",
            "model": "qwen3-vl-flash",
            "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1",
            "apiKeyEnv": "DASHSCOPE_API_KEY",
            "prompt": "qwenvl markdown"
          }
        }
      }
    },
    "skillsDir": "./skills",
    "rolePromptDir": "./roles/contract-manager",
    "sessionDb": "./data/sessions.db"
  },
  "contractMcp": {
    "_libraryRoot": "\\\\192.168.20.100\\启迪之星\\技术商业化事业部\\板块-产业化\\合同管理",
    "libraryRoot": "storage/contract-library",
    "contractIdPrefix": "CT",
    "allowedExtensions": [".pdf", ".doc", ".docx", ".jpg", ".jpeg", ".png"],
    "maxFileSizeMb": 50,
    "defaultSearchLimit": 20
  },
  "channel": {
    "type": "wxwork",
    "wxwork": {
      "debug": true,
      "streamingResponse": true
    }
  },
  "storage": {
    "tempDir": "./storage/temp"
  }
}
